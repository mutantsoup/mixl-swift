# Required: your real MixLayer API key. Kept server-side only — never shipped to clients.
MIXLAYER_API_KEY=your-mixlayer-api-key

# Optional overrides (defaults shown).
MIXLAYER_BASE_URL=https://models.mixlayer.ai/v1
PROXY_MOUNT_PATH=/mixlayer/v1
PORT=8787

# Request logging (keys are always masked). Set to false to silence.
PROXY_LOG=true
